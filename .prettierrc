{
  "printWidth": 100,
  "singleQuote": true,
  "quoteProps": "preserve",
  "semi": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "bracketSpacing": false,
  "jsxSingleQuote": false,
  "arrowParens": "avoid",
  "overrides": [
    {
      "files": "*.html",
      "options": {
        "parser": "angular"
      }
    },
    {
      "files": ["*.yaml", "*.yml"],
      "options": {
        "singleQuote": false
      }
    },
    {
      "files": "docs/**/*.md",
      "options": {
        "embeddedLanguageFormatting": "off",
        "tabWidth": 4
      }
    }
  ]
}
