{
  "name": "@a2ui/mcp-apps-in-a2ui-sample",
  "private": true,
  "version": "0.1.0",
  "description": "A2UI MCP App Sample",
  "main": "./dist/mcp-app.js",
  "types": "./dist/mcp-app.d.ts",
  "type": "module",
  "scripts": {
    "prepack": "yarn build",
    "build": "wireit",
    "build:tsc": "wireit",
    "dev": "yarn serve --watch",
    "test": "wireit",
    "serve": "wireit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "wireit": {
    "serve": {
      "command": "vite dev",
      "dependencies": [
        "build"
      ],
      "service": true
    },
    "test": {
      "command": "node --test --enable-source-maps --test-reporter spec dist/src/**/*.test.js",
      "dependencies": [
        "build"
      ]
    },
    "build": {
      "dependencies": [
        "build:tsc"
      ]
    },
    "build:tsc": {
      "command": "tsc -b --pretty",
      "env": {
        "FORCE_COLOR": "1"
      },
      "files": [
        "**/*.ts",
        "tsconfig.json"
      ],
      "output": [
        "dist/",
        "!dist/**/*.min.js{,.map}"
      ],
      "clean": "if-file-deleted"
    }
  },
  "repository": {
    "directory": "samples/client/lit/mcp-apps-in-a2ui-sample",
    "type": "git",
    "url": "git+https://github.com/a2ui-project/a2ui.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [],
  "author": "Google",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/a2ui-project/a2ui/issues"
  },
  "homepage": "https://github.com/a2ui-project/a2ui/tree/main/web#readme",
  "devDependencies": {
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "typescript": "5.9.3",
    "uuid": "^14.0.0",
    "vite": "^8.0.16",
    "wireit": "^0.15.0-pre.2"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@a2ui/lit": "^0.10.0",
    "@a2ui/web_core": "^0.10.0",
    "@lit-labs/signals": "^0.3.0",
    "@lit/context": "^1.1.6",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "lit": "^3.3.3"
  }
}
