{
  "name": "@a2ui/react",
  "version": "0.10.2",
  "license": "Apache-2.0",
  "description": "React renderer for A2UI (Agent-to-User Interface)",
  "homepage": "https://a2ui.org/",
  "repository": {
    "directory": "renderers/react",
    "type": "git",
    "url": "git+https://github.com/a2ui-project/a2ui.git"
  },
  "bugs": {
    "url": "https://github.com/a2ui-project/a2ui/issues"
  },
  "keywords": [
    "a2ui",
    "react",
    "ai",
    "agent",
    "ui",
    "renderer"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./v0_8": {
      "import": {
        "types": "./dist/v0_8/index.d.ts",
        "default": "./dist/v0_8/index.js"
      },
      "require": {
        "types": "./dist/v0_8/index.d.cts",
        "default": "./dist/v0_8/index.cjs"
      }
    },
    "./v0_9": {
      "import": {
        "types": "./dist/v0_9/index.d.ts",
        "default": "./dist/v0_9/index.js"
      },
      "require": {
        "types": "./dist/v0_9/index.d.cts",
        "default": "./dist/v0_9/index.cjs"
      }
    },
    "./styles": {
      "import": {
        "types": "./dist/styles/index.d.ts",
        "default": "./dist/styles/index.js"
      },
      "require": {
        "types": "./dist/styles/index.d.cts",
        "default": "./dist/styles/index.cjs"
      }
    },
    "./styles/structural.css": "./dist/structural.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "prepublishOnly": "node -e \"if(!process.cwd().endsWith('dist')) { console.error('Error: This package must be published from the dist/ directory. Run `yarn build` then `cd dist && yarn npm publish`'); process.exit(1); }\"",
    "publish:package": "yarn build && node ../scripts/prepare-publish.mjs && cd dist && touch yarn.lock && yarn install && yarn npm publish --access public",
    "build": "wireit",
    "demo": "yarn workspace @a2ui/react-explorer dev",
    "test": "wireit",
    "test:unit": "wireit",
    "test:integration": "wireit",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "clean": "wireit"
  },
  "dependencies": {
    "@a2ui/markdown-it": "*",
    "@a2ui/web_core": "workspace:*",
    "clsx": "^2.1.1",
    "markdown-it": "^14.2.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "gts": "^7.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "puppeteer": "^25.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wireit": "^0.15.0-pre.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "wireit": {
    "build": {
      "command": "tsup && node scripts/postbuild.mjs",
      "dependencies": [
        "../../renderers/web_core:build"
      ],
      "files": [
        "src/**/*",
        "tsconfig.json",
        "scripts/**/*"
      ],
      "output": [
        "dist/"
      ]
    },
    "test": {
      "dependencies": [
        "test:unit",
        "test:integration"
      ]
    },
    "test:unit": {
      "command": "vitest run",
      "dependencies": [
        "build"
      ],
      "files": [
        "src/**/*",
        "tsconfig.json"
      ]
    },
    "test:integration": {
      "command": "yarn workspace @a2ui/react-explorer test:ci"
    },
    "clean": {
      "command": "rm -rf dist .tsbuildinfo .wireit"
    }
  }
}
