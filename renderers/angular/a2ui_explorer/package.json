{
  "name": "@a2ui/angular-explorer",
  "private": true,
  "version": "0.10.2",
  "description": "A2UI Angular Explorer",
  "type": "module",
  "scripts": {
    "generate-examples": "wireit",
    "build:deps": "wireit",
    "dev": "yarn build:deps && ng serve a2ui_explorer",
    "build": "wireit",
    "test": "wireit",
    "test:integration": "wireit",
    "build:closure-compiler": "wireit",
    "test:closure-compiler": "wireit",
    "dev:closure-compiler": "yarn build:closure-compiler && node scripts/closure-compiler/serve-dist.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "wireit",
    "format": "prettier --ignore-path ../../../.prettierignore --write .",
    "format:check": "prettier --ignore-path ../../../.prettierignore --check ."
  },
  "wireit": {
    "build:deps": {
      "dependencies": [
        "generate-examples",
        "../../web_core:build",
        "../../markdown/markdown-it:build",
        "../:build"
      ]
    },
    "build:closure-compiler": {
      "command": "ng build a2ui_explorer --configuration development && node scripts/closure-compiler/apply-closure-compiler.mjs",
      "dependencies": [
        "build:deps"
      ]
    },
    "generate-examples": {
      "command": "node scripts/generate-examples.mjs",
      "files": [
        "../../../specification/v0_8/json/catalogs/**/*.json",
        "../../../specification/v0_9/catalogs/**/*.json",
        "scripts/generate-examples.mjs"
      ],
      "output": [
        "src/app/generated/examples-bundle.ts"
      ]
    },
    "build": {
      "command": "ng build a2ui_explorer",
      "dependencies": [
        "build:deps"
      ]
    },
    "test": {
      "dependencies": [
        "test:integration",
        "test:closure-compiler"
      ]
    },
    "test:integration": {
      "command": "ng test a2ui_explorer --watch=false --browsers=ChromeHeadless",
      "dependencies": [
        "build:deps"
      ]
    },
    "test:closure-compiler": {
      "command": "playwright test -c playwright.closure-compiler.config.ts",
      "dependencies": [
        "build:closure-compiler"
      ]
    },
    "clean": {
      "command": "rm -rf dist .tsbuildinfo .wireit src/app/generated"
    }
  },
  "dependencies": {
    "@a2ui/angular": "workspace:*",
    "@a2ui/markdown-it": "workspace:*",
    "@a2ui/web_core": "workspace:*",
    "@angular/common": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@preact/signals-core": "^1.14.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/compiler-cli": "^21.2.5",
    "@playwright/test": "1.58.1",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^25.9.3",
    "eslint": "^10.4.1",
    "google-closure-compiler": "^20260429.0.0",
    "jasmine-core": "^6.3.0",
    "prettier": "^3.8.4",
    "typescript": "5.9.3",
    "wireit": "^0.15.0-pre.2"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
